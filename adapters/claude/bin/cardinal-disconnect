#!/usr/bin/env python3
"""cardinal-disconnect — remove the Cardinal plugin's config from this install.

What gets removed:
  - The OTel env keys this plugin owns from ~/.claude/settings.json
    (any non-plugin env entries are left untouched).
  - CARDINAL_MCP_URL + CARDINAL_MCP_API_KEY from the same env block
    (these were what wired the plugin-declared `cardinal` MCP server).
  - ~/.claude/cardinal.json (state file).

What gets revoked server-side (best effort):
  - The MCP API key, via POST <host>/api/maestro-keys/<mcp_key_id>/revoke.
    The plugin holds the plaintext via the env block so it authenticates
    as the key itself (R11 §1 "self" path).
  - The ingest key is NOT revoked here yet — the maestro endpoint hasn't
    shipped. The script prints a pointer to the admin UI.
"""

import argparse
import json
import sys
import urllib.error
import urllib.request
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "hooks"))
from cardinal_core.paths import backup  # noqa: E402

CLAUDE_DIR = Path.home() / ".claude"
SETTINGS_PATH = CLAUDE_DIR / "settings.json"
STATE_PATH = CLAUDE_DIR / "cardinal.json"

OWNED_ENV_KEYS = {
    # Telemetry side
    "CLAUDE_CODE_ENABLE_TELEMETRY",
    "CLAUDE_CODE_ENHANCED_TELEMETRY_BETA",
    "OTEL_METRICS_EXPORTER",
    "OTEL_LOGS_EXPORTER",
    "OTEL_TRACES_EXPORTER",
    "OTEL_EXPORTER_OTLP_PROTOCOL",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_EXPORTER_OTLP_HEADERS",
    "OTEL_RESOURCE_ATTRIBUTES",
    "OTEL_LOG_TOOL_DETAILS",
    # MCP side (substituted into plugins/cardinal/.mcp.json)
    "CARDINAL_MCP_URL",
    "CARDINAL_MCP_API_KEY",
}

MCP_ENV_KEYS = {"CARDINAL_MCP_URL", "CARDINAL_MCP_API_KEY"}
TELEMETRY_ENV_KEYS = OWNED_ENV_KEYS - MCP_ENV_KEYS


def revoke_mcp_key(host: str, key_id: str, plaintext: str | None) -> tuple[bool, str]:
    """Best-effort POST /api/maestro-keys/<id>/revoke. Authenticates with the
    plaintext (R11 §1 self path); without it the server returns 403 and we
    point the user at the admin UI."""
    url = host.rstrip("/") + f"/api/maestro-keys/{key_id}/revoke"
    headers = {"content-type": "application/json"}
    if plaintext:
        headers["X-CardinalHQ-API-Key"] = plaintext
    req = urllib.request.Request(url, data=b"", method="POST", headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return resp.status in (200, 204), f"HTTP {resp.status}"
    except urllib.error.HTTPError as e:
        return False, f"HTTP {e.code}"
    except (urllib.error.URLError, TimeoutError) as e:
        return False, f"network error: {e}"


def strip_env_keys(settings_path: Path, keys: set[str]) -> int:
    """Strip the given keys from settings.json's env. Returns the number
    removed. Refuses on malformed JSON."""
    if not settings_path.exists():
        return 0
    try:
        settings = json.loads(settings_path.read_text())
    except Exception as e:
        sys.exit(f"refusing to modify: {settings_path} is malformed ({e})")
    env = settings.get("env", {})
    if not isinstance(env, dict):
        return 0
    before = len(env)
    for key in keys:
        env.pop(key, None)
    after = len(env)
    if not env:
        settings.pop("env", None)
    else:
        settings["env"] = env
    settings_path.write_text(json.dumps(settings, indent=2) + "\n")
    return before - after


def _read_mcp_plaintext_from_settings() -> str | None:
    """Read the live MCP plaintext from settings.json's env block. This is
    where v0.3 stores it; v0.2 wrote to ~/.claude.json. Returns None if
    unset or the file is unreadable."""
    if not SETTINGS_PATH.exists():
        return None
    try:
        data = json.loads(SETTINGS_PATH.read_text())
    except Exception:
        return None
    env = data.get("env") or {}
    if not isinstance(env, dict):
        return None
    val = env.get("CARDINAL_MCP_API_KEY")
    return val if isinstance(val, str) else None


def main() -> int:
    p = argparse.ArgumentParser(prog="cardinal-disconnect")
    p.add_argument("--force", action="store_true",
                   help="Don't fail if the state file is missing.")
    p.add_argument("--keep-telemetry", action="store_true",
                   help="Remove only the MCP side. Keeps the OTel env block "
                        "in place. Useful for going from telemetry-and-mcp "
                        "back to telemetry-only without re-running connect.")
    args = p.parse_args()

    if not STATE_PATH.exists() and not args.force:
        print("Cardinal is not connected. Nothing to do.")
        return 0

    state: dict = {}
    if STATE_PATH.exists():
        try:
            state = json.loads(STATE_PATH.read_text())
        except Exception as e:
            sys.exit(f"refusing to proceed: {STATE_PATH} is malformed ({e})")

    host = state.get("host") or "https://app.cardinalhq.io"
    mcp_key_id = state.get("mcp_key_id")
    ingest_key_id = state.get("ingest_key_id")

    # ---- Revoke MCP key server-side (best effort) ------------------------
    if mcp_key_id:
        plaintext = _read_mcp_plaintext_from_settings()
        ok, msg = revoke_mcp_key(host, mcp_key_id, plaintext)
        if ok:
            print(f"  ✓ Revoked MCP key {state.get('mcp_key_prefix') or mcp_key_id} server-side ({msg})")
        else:
            print(f"  ⚠ Could not revoke MCP key server-side ({msg}).")
            print(f"    Visit {host}/settings/api-keys to revoke it manually.")

    # ---- Strip env keys ---------------------------------------------------
    if SETTINGS_PATH.exists():
        bk = backup(SETTINGS_PATH)
        if args.keep_telemetry:
            removed = strip_env_keys(SETTINGS_PATH, MCP_ENV_KEYS)
            if removed:
                print(f"  ✓ Removed {removed} MCP env key(s) from {SETTINGS_PATH}")
        else:
            removed = strip_env_keys(SETTINGS_PATH, OWNED_ENV_KEYS)
            if removed:
                print(f"  ✓ Removed {removed} plugin-owned env key(s) from {SETTINGS_PATH}")
        if bk and removed:
            print(f"    Backup → {bk}")

    # ---- State file -------------------------------------------------------
    if not args.keep_telemetry:
        if STATE_PATH.exists():
            STATE_PATH.unlink()
            print(f"  ✓ Removed {STATE_PATH}")
        if ingest_key_id:
            print()
            print("  Note: the ingest API key is still active server-side. The")
            print("        device-code-issued ingest revoke endpoint hasn't shipped")
            print(f"        yet; revoke it via {host}/settings/api-keys when you can.")
    else:
        # Re-stamp state with mode=telemetry-only and mcp_* fields stripped.
        if state:
            state["mode"] = "telemetry-only"
            for k in ("mcp_url", "mcp_key_id", "mcp_key_prefix", "mcp_created_at"):
                state.pop(k, None)
            STATE_PATH.write_text(json.dumps(state, indent=2) + "\n")
            print(f"  ✓ Updated {STATE_PATH} → mode=telemetry-only")

    print()
    print("✓ Local config updated. Restart Claude Code so it picks up the change.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
