#!/usr/bin/env python3
"""Connect Gemini CLI to Cardinal telemetry and MCP.

Runs Cardinal's device-code flow, mints ingest and MCP keys, verifies both
endpoints, writes a managed Cardinal extension bundle under
~/.gemini/extensions/cardinal/, and adds the OTLP `telemetry` block to
~/.gemini/settings.json so Gemini's native exporter ships to Cardinal
alongside the hook-emitted events.

Monorepo adapter: the device-code flow, endpoint reachability probes, and
atomic file writers come from the vendored `cardinal_core` package. This
script keeps only Gemini-specific install logic — the extension bundle
and the settings.json writer.
"""

from __future__ import annotations

import argparse
import json
import os
import shlex
import shutil
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "hooks"))
from cardinal_core import deviceflow  # noqa: E402
from cardinal_core.paths import (  # noqa: E402
    AgentPaths,
    atomic_write,
    atomic_write_secret,
    backup,
)


def _load_plugin_version() -> str:
    manifest = Path(__file__).resolve().parent.parent / ".gemini-plugin" / "plugin.json"
    try:
        return json.loads(manifest.read_text(encoding="utf-8")).get("version") or "unknown"
    except (OSError, ValueError):
        return "unknown"


PLUGIN_VERSION = _load_plugin_version()
CLIENT_ID = "cardinal-gemini-plugin"
MCP_SERVER_NAME = "cardinal"
EXTENSION_NAME = "cardinal"

PLUGIN_ROOT = Path(__file__).resolve().parent.parent
HOOK_SCRIPT = PLUGIN_ROOT / "hooks" / "cardinal-gemini-telemetry.py"
EXTENSION_SOURCE = PLUGIN_ROOT / "extension"

GEMINI_DIR = Path.home() / ".gemini"
PATHS = AgentPaths(home=GEMINI_DIR)
SETTINGS_PATH = GEMINI_DIR / "settings.json"
EXTENSIONS_DIR = GEMINI_DIR / "extensions"
EXTENSION_INSTALL_DIR = EXTENSIONS_DIR / EXTENSION_NAME
STATE_PATH = PATHS.state_path
SECRETS_PATH = PATHS.secrets_path
PENDING_PATH = PATHS.pending_path


def write_pending(grant: dict) -> None:
    payload = {
        "verification_uri": grant.get("verification_uri", ""),
        "user_code": grant.get("user_code", ""),
        "expires_in": grant.get("expires_in", deviceflow.DEFAULT_POLL_TIMEOUT_SECS),
        "written_at": datetime.now(timezone.utc).isoformat(),
        "plugin_version": PLUGIN_VERSION,
    }
    atomic_write(PENDING_PATH, json.dumps(payload, indent=2) + "\n")


def clear_pending() -> None:
    try:
        PENDING_PATH.unlink()
    except FileNotFoundError:
        pass


def load_json_object(path: Path, label: str) -> dict:
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text())
    except json.JSONDecodeError as exc:
        sys.exit(f"Refusing to write: {label} ({path}) is not valid JSON ({exc}).")
    if not isinstance(data, dict):
        sys.exit(f"Refusing to write: {label} ({path}) is not a JSON object.")
    return data


# ---------------------------------------------------------------------------
# Extension bundle install
# ---------------------------------------------------------------------------

def install_extension_bundle(mcp_url: str | None, mcp_key: str | None) -> None:
    """Copy the plugin's extension/ into ~/.gemini/extensions/cardinal/.

    The gemini-extension.json manifest is materialized with concrete
    mcpServers values (no `${VAR}` placeholders — Gemini's manifest
    variable-substitution semantics are unstable across releases).
    hooks/hooks.json's `__HOOK_SCRIPT__` placeholder is replaced with the
    absolute path to this plugin's telemetry hook.
    """
    if EXTENSION_INSTALL_DIR.exists():
        shutil.rmtree(EXTENSION_INSTALL_DIR)
    EXTENSION_INSTALL_DIR.mkdir(parents=True, exist_ok=True)

    # GEMINI.md — copy verbatim.
    shutil.copy(EXTENSION_SOURCE / "GEMINI.md", EXTENSION_INSTALL_DIR / "GEMINI.md")

    # gemini-extension.json — materialize concrete mcpServers when present.
    manifest = json.loads((EXTENSION_SOURCE / "gemini-extension.json").read_text())
    if mcp_url and mcp_key:
        manifest["mcpServers"] = {
            MCP_SERVER_NAME: {
                "url": mcp_url,
                "headers": {"X-CardinalHQ-API-Key": mcp_key},
            }
        }
    else:
        manifest.pop("mcpServers", None)
    manifest["cardinalManaged"] = True
    (EXTENSION_INSTALL_DIR / "gemini-extension.json").write_text(
        json.dumps(manifest, indent=2) + "\n"
    )

    # hooks/hooks.json — patch __HOOK_SCRIPT__ placeholder.
    hooks_src = (EXTENSION_SOURCE / "hooks" / "hooks.json").read_text()
    hooks_patched = hooks_src.replace(
        "__HOOK_SCRIPT__", shlex.quote(str(HOOK_SCRIPT)).strip("'")
    )
    (EXTENSION_INSTALL_DIR / "hooks").mkdir(exist_ok=True)
    (EXTENSION_INSTALL_DIR / "hooks" / "hooks.json").write_text(hooks_patched)


# ---------------------------------------------------------------------------
# settings.json — telemetry + (fallback) mcpServers + hooks
# ---------------------------------------------------------------------------

_TELEMETRY_KEY = "telemetry"


def apply_settings(ingest: dict, mcp_url: str | None, mcp_key: str | None,
                   include_hooks: bool) -> Path | None:
    """Merge Cardinal-managed keys into ~/.gemini/settings.json.

    Always writes:
      - `telemetry` block pointing at Cardinal's OTLP ingest endpoint.

    When `include_hooks=True` (no-extension install path only):
      - `mcpServers.cardinal`
      - `hooks.<Event>` entries tagged `cardinalManaged: true` per hook
        handler so cardinal-disconnect can strip them precisely.
    """
    settings = load_json_object(SETTINGS_PATH, "settings.json")

    settings[_TELEMETRY_KEY] = {
        "enabled": True,
        "target": "otlp",
        "otlpEndpoint": str(ingest["endpoint"]).rstrip("/") + "/v1/logs",
        "otlpHeaders": {
            (ingest.get("api_header") or "x-cardinalhq-api-key"): ingest["api_key"],
        },
        "logPrompts": False,
        "cardinalManaged": True,
    }

    if include_hooks:
        if mcp_url and mcp_key:
            servers = settings.get("mcpServers") if isinstance(settings.get("mcpServers"), dict) else {}
            servers[MCP_SERVER_NAME] = {
                "url": mcp_url,
                "headers": {"X-CardinalHQ-API-Key": mcp_key},
                "cardinalManaged": True,
            }
            settings["mcpServers"] = servers

        hooks_root = settings.get("hooks") if isinstance(settings.get("hooks"), dict) else {}
        for event, timeout in (
            ("SessionStart", 5),
            ("BeforeAgent", 5),
            ("AfterModel", 5),
            ("AfterTool", 5),
            ("AfterAgent", 5),
            ("PreCompress", 5),
            ("SessionEnd", 5),
        ):
            groups = hooks_root.get(event) if isinstance(hooks_root.get(event), list) else []
            # Strip prior Cardinal-managed entries before re-appending.
            groups = [
                g for g in groups
                if not (isinstance(g, dict) and g.get("cardinalManaged"))
            ]
            groups.append({
                "matcher": "",
                "cardinalManaged": True,
                "hooks": [{
                    "type": "command",
                    "command": (
                        f"python3 {shlex.quote(str(HOOK_SCRIPT))} "
                        f"--event {shlex.quote(event)} # cardinal-gemini-plugin"
                    ),
                    "timeout": timeout,
                }],
            })
            hooks_root[event] = groups
        settings["hooks"] = hooks_root

    backup_path = backup(SETTINGS_PATH)
    atomic_write(SETTINGS_PATH, json.dumps(settings, indent=2) + "\n")
    return backup_path


def write_secrets(bundle: dict) -> None:
    ingest = bundle.get("ingest") or {}
    mcp = bundle.get("mcp") or {}
    payload = {
        "schema_version": 1,
        "ingest_api_key": ingest.get("api_key"),
        "ingest_api_header": ingest.get("api_header") or "x-cardinalhq-api-key",
        "mcp_api_key": mcp.get("api_key"),
        "written_at": datetime.now(timezone.utc).isoformat(),
    }
    atomic_write_secret(SECRETS_PATH, json.dumps(payload, indent=2) + "\n")


def write_state(bundle: dict, host: str, deployment_env: str,
                telemetry_only: bool, no_extension: bool) -> None:
    org = bundle.get("org", {})
    user = bundle.get("user", {})
    mcp = bundle.get("mcp") or {}
    ingest = bundle.get("ingest") or {}
    mode = (
        "telemetry-only" if telemetry_only or not mcp
        else "mcp-only" if not ingest
        else "telemetry-and-mcp"
    )
    state = {
        "schema_version": 1,
        "host": host,
        "mode": mode,
        "install_shape": "settings" if no_extension else "extension",
        "org_id": org.get("id"),
        "org_slug": org.get("slug"),
        "user_email": user.get("email"),
        "deployment_environment": deployment_env,
        "plugin_version": PLUGIN_VERSION,
        "written_at": datetime.now(timezone.utc).isoformat(),
        "settings_path": str(SETTINGS_PATH),
        "extension_dir": str(EXTENSION_INSTALL_DIR) if not no_extension else None,
        "secrets_path": str(SECRETS_PATH),
        "telemetry": {"enabled": bool(ingest)},
    }
    if ingest:
        state["ingest_endpoint"] = ingest.get("endpoint")
        state["ingest_key_id"] = ingest.get("key_id")
        state["ingest_key_prefix"] = (ingest.get("api_key") or "")[:8]
    if mcp:
        state["mcp_url"] = mcp.get("url")
        state["mcp_key_id"] = mcp.get("key_id")
        state["mcp_key_prefix"] = mcp.get("key_prefix") or (mcp.get("api_key") or "")[:8]
        state["mcp_created_at"] = mcp.get("created_at")
    limits = bundle.get("limits")
    if isinstance(limits, dict) and limits.get("status_url"):
        state["limits"] = {
            "status_url": limits["status_url"],
            "enabled": bool(limits.get("enabled", True)),
        }
    atomic_write(STATE_PATH, json.dumps(state, indent=2) + "\n")


def continue_after_grant(args: argparse.Namespace, grant: dict) -> int:
    expires_in = int(grant.get("expires_in") or deviceflow.DEFAULT_POLL_TIMEOUT_SECS)
    interval = int(grant.get("interval") or deviceflow.DEFAULT_POLL_INTERVAL_SECS)
    verification_uri = grant.get("verification_uri") or ""

    print()
    print("Open this URL in your browser to approve Cardinal for Gemini CLI:")
    print(f"  {verification_uri}")
    print()
    print(f"Waiting up to {expires_in // 60} minute(s) for browser approval...")

    bundle = deviceflow.poll_device_token(
        args.host, grant["device_code"], CLIENT_ID, interval, expires_in
    )
    org = bundle.get("org", {})
    user = bundle.get("user", {})
    ingest = bundle.get("ingest")
    mcp = bundle.get("mcp")

    if not ingest:
        sys.exit("Cardinal did not return an ingest credential. Check the requested scopes.")
    if not args.telemetry_only and not mcp:
        sys.exit("Cardinal did not return an MCP credential. Check the requested scopes.")

    deployment_env = args.deployment_env or deviceflow.derive_deployment_env(args.host)

    if args.dry_run:
        print(json.dumps({
            "org": org,
            "user": user,
            "deployment_env": deployment_env,
            "would_write": {
                "settings": str(SETTINGS_PATH),
                "extension_dir": str(EXTENSION_INSTALL_DIR) if not args.no_extension else None,
                "state": str(STATE_PATH),
                "secrets": str(SECRETS_PATH),
                "ingest_endpoint": ingest.get("endpoint"),
                "mcp_url": (mcp or {}).get("url"),
            },
        }, indent=2))
        return 0

    ok, msg = deviceflow.verify_ingest_reachable(ingest)
    if not ok:
        sys.exit(f"Ingest reachability failed: {msg}")
    print(f"Ingest endpoint reachable ({msg})")

    if mcp:
        ok, msg = deviceflow.verify_mcp_reachable(mcp.get("url"), mcp.get("api_key"))
        if not ok:
            sys.exit(f"MCP reachability failed: {msg}")
        print(f"MCP endpoint reachable ({msg})")

    if not HOOK_SCRIPT.exists():
        sys.exit(f"Telemetry hook script is missing: {HOOK_SCRIPT}")

    mcp_url = mcp.get("url") if mcp else None
    mcp_key = mcp.get("api_key") if mcp else None

    if not args.no_extension:
        install_extension_bundle(mcp_url, mcp_key)
        print(f"Installed Cardinal extension to {EXTENSION_INSTALL_DIR}")

    settings_backup = apply_settings(
        ingest, mcp_url, mcp_key, include_hooks=args.no_extension
    )
    print(f"Wrote Cardinal telemetry config to {SETTINGS_PATH}")
    if settings_backup:
        print(f"Settings backup: {settings_backup}")

    write_secrets(bundle)
    print(f"Wrote Cardinal local secrets to {SECRETS_PATH}")

    write_state(bundle, args.host, deployment_env, args.telemetry_only, args.no_extension)
    print(f"Wrote Cardinal state to {STATE_PATH}")

    print()
    print(f"Connected as {user.get('email') or 'unknown'} ({org.get('slug') or org.get('id')})")
    print(f"Telemetry endpoint: {ingest['endpoint']}")
    if mcp:
        print(f"MCP endpoint: {mcp['url']}")
    print()
    print("Restart Gemini CLI so it reloads settings and (re)loads the Cardinal extension,")
    print("then run cardinal-status.")
    return 0


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="cardinal-connect",
        description="Connect Gemini CLI to Cardinal's unified MCP endpoint and telemetry.",
    )
    parser.add_argument("--host", default="https://app.cardinalhq.io",
                        help="Cardinal app host (default: https://app.cardinalhq.io)")
    parser.add_argument("--rotate", action="store_true",
                        help="Proceed even if Cardinal state already exists and mint a fresh key.")
    parser.add_argument("--telemetry-only", action="store_true",
                        help="Only configure Cardinal telemetry; skip the MCP credential.")
    parser.add_argument("--no-extension", action="store_true",
                        help="Skip the ~/.gemini/extensions/cardinal/ bundle and merge "
                             "mcpServers + hooks directly into ~/.gemini/settings.json.")
    parser.add_argument("--deployment-env", default=None,
                        help="Override deployment.environment (default derived from --host).")
    parser.add_argument("--dry-run", action="store_true",
                        help="Run the device-code flow and print what would be written.")
    return parser.parse_args()


def main() -> int:
    args = parse_args()

    if STATE_PATH.exists() and not args.rotate:
        try:
            prior = json.loads(STATE_PATH.read_text())
        except Exception:
            prior = {}
        user = prior.get("user_email") or "this account"
        sys.stderr.write(
            f"Cardinal is already connected as {user}. "
            "Re-run with --rotate to overwrite.\n"
        )
        return 2

    scopes = ["ingest:write"]
    if not args.telemetry_only:
        scopes.append("mcp:invoke")
    print(f"Requesting Cardinal consent for scopes: {', '.join(scopes)}")
    try:
        grant = deviceflow.start_device_code(args.host, scopes, CLIENT_ID)
        write_pending(grant)
        try:
            return continue_after_grant(args, grant)
        finally:
            clear_pending()
    except deviceflow.DeviceFlowError as exc:
        sys.exit(str(exc))


if __name__ == "__main__":
    sys.exit(main())
