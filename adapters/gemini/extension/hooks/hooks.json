{
  "_comment": "Extension-scoped hook registrations. The `command` string is rewritten by cardinal-connect at install time to reference the plugin's absolute path.",
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "python3 __HOOK_SCRIPT__ --event SessionStart # cardinal-gemini-plugin",
          "timeout": 5
        }
      ]
    }
